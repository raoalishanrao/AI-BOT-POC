# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Chat provider: gemini or groq
CHAT_PROVIDER=groq

# Gemini (embeddings always use Gemini; chat if CHAT_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Groq (chat if CHAT_PROVIDER=groq) — https://console.groq.com/docs/rate-limits
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_PROFILE_MODEL=llama-3.1-8b-instant
# Comma-separated fallbacks when a model hits rate limits or is unavailable
GROQ_CHAT_FALLBACK_MODELS=llama-3.1-8b-instant,openai/gpt-oss-20b
GROQ_PROFILE_FALLBACK_MODELS=llama-3.1-8b-instant,openai/gpt-oss-20b
# If all Groq models fail, use Gemini when GEMINI_API_KEY is set
CHAT_FALLBACK_TO_GEMINI=true

# Embeddings for RAG search (Gemini only)
EMBEDDING_MODEL=gemini-embedding-001

# Optional
INGEST_BATCH_SIZE=20
CHAT_MATCH_COUNT=12
CHAT_HISTORY_LIMIT=20
API_HOST=127.0.0.1
API_PORT=8000
